{
  "name": "temp-dashboard-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:filtered-spec": "node scripts/filter-openapi.js",
    "generate:spec-html": "npm run generate:filtered-spec && redocly build-docs public/dashboard-openapi.yaml --output public/dashboardSpec.html --title \"Dashboard API Reference\" --disableGoogleFont --template scripts/redoc-template.hbs",
    "predev": "npm run generate:spec-html",
    "dev": "next dev",
    "prebuild": "npm run generate:spec-html",
    "build": "next build",
    "prestart": "npm run generate:spec-html",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@redocly/cli": "^2.28.0",
    "next": "16.2.3",
    "nextra": "^4.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
